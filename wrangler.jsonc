{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mogos-cresco",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-27",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application"
  },
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
